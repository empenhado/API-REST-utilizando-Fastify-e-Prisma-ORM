
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  idCliente String   @id @default(uuid())
  nome      String
  email     String 
  pedidos   Pedido[]

  @@map("cliente")
}

model Produto {
  idProduto String    @id @default(uuid())
  nome      String
  preco     Float
  pedidos   Pedido[] 

  @@map("produto") 
}

model Pedido {
  idPedido  String     @id @default(uuid())
  clienteId String
  cliente   Cliente    @relation(fields: [clienteId], references: [idCliente])
  produtos  Produto[]  
  valorTotal Float
  CreatedAt  DateTime   @default(now())

  @@map("pedido")
}
